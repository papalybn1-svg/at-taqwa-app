{
  "expo": {
    "name": "At-Taqwa",
    "owner": "attaqwa",
    "slug": "at-taqwa-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/LOGO_AT_TAQWA.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.attaqwa.app",

      "buildNumber": "2.1.3",
      
      "icon": "./assets/LOGO_AT_TAQWA.png",
      "associatedDomains": ["applinks:attaqwa-confidentialite.vercel.app"],
      "infoPlist": {
        "CFBundleDisplayName": "At-Taqwa",
        "CFBundleName": "At-Taqwa",
        "NSCameraUsageDescription": "Cette application nécessite l'accès à la caméra pour certaines fonctionnalités.",
        "NSPhotoLibraryUsageDescription": "Cette application nécessite l'accès à la galerie pour certaines fonctionnalités.",
        "NSLocationWhenInUseUsageDescription": "Cette application nécessite l'accès à votre localisation pour calculer les heures de prière précises selon votre position géographique.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Cette application nécessite l'accès à votre localisation pour calculer les heures de prière et vous envoyer des notifications de rappel.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo_fond_transparent.png",
        "backgroundColor": "#2E8B57"
      },
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "attaqwa-confidentialite.vercel.app",
              "pathPrefix": "/"
            }
          ],
          "category": ["BROWSABLE", "DEFAULT"]
        }
      ],
      "edgeToEdgeEnabled": false,
      "enableHermes": true,
      "softwareKeyboardLayoutMode": "resize",
      "package": "com.attaqwa.app",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "VIBRATE",
        "RECEIVE_BOOT_COMPLETED",
        "WAKE_LOCK"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-web-browser"
    ],
    "scheme": "attaqwa",
    "extra": {
      "eas": {
        "projectId": "7adb7538-df61-4e7b-bfb9-faa37d646dc1"
      }
    }
  }
}
