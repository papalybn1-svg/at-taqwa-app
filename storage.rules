rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Règles pour les avatars des utilisateurs
    match /avatars/{userId} {
      // Permettre la lecture à tous les utilisateurs authentifiés
      allow read: if request.auth != null;
      
      // Permettre l'écriture seulement à l'utilisateur propriétaire
      allow write: if request.auth != null 
                   && request.auth.uid == userId.split('_')[0]
                   && request.resource.size < 10 * 1024 * 1024 // Max 10MB
                   && request.resource.contentType.matches('image/.*');
    }
    
    // Règles par défaut - refuser tout accès
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
} 